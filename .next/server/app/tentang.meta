{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/tentang/layout,_N_T_/tentang/page,_N_T_/tentang"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/tentang/__PAGE__",
    "/tentang",
    "/_index",
    "/_head"
  ]
}